{
  "name": "@paperclipai/plugin-social-monitor",
  "version": "0.1.0",
  "description": "Monitoramento de menções da marca nas redes sociais — Twitter, Instagram, TikTok, Reddit",
  "type": "module",
  "private": true,
  "exports": { ".": "./src/index.ts" },
  "paperclipPlugin": { "manifest": "./dist/manifest.js", "worker": "./dist/worker.js", "ui": "./dist/ui/" },
  "scripts": {
    "prebuild": "node ../../../../scripts/ensure-plugin-build-deps.mjs",
    "build": "tsc && node ./scripts/build-ui.mjs",
    "clean": "rm -rf dist"
  },
  "dependencies": { "@paperclipai/plugin-sdk": "workspace:*", "@paperclipai/shared": "workspace:*" },
  "devDependencies": { "esbuild": "^0.27.3", "@types/node": "^24.6.0", "@types/react": "^19.0.8", "@types/react-dom": "^19.0.3", "react": "^19.0.0", "react-dom": "^19.0.0", "typescript": "^5.7.3" },
  "peerDependencies": { "react": ">=18" }
}
